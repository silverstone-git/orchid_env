:     a = random.randint(1, 100)     b = random.randint(1, 100)     choice = random.choice(formulas)     f_str = choice.format(a=a, b=b)          if choice.startswith(\"\\\\frac\"):         if is_prime(b):             latex_sum += a                  lines.append(f\"METRIC_LATEX - Performance equation: $ {f_str} $ evaluated at t={random.randint(0, 100)}\\n\")  # Pad to exactly 10000 lines while len(lines) < 10000:     lines.append(\"NOOP - System idle\\n\")  random.shuffle(lines)  with open(\"server/complex_data.log\", \"w\") as f:     f.writelines(lines)  print(f\"JSON_GT={round(json_gt_sum, 2)}\") print(f\"REGEX_GT={sorted(list(fail_ips))}\") print(f\"LATEX_GT={latex_sum}\") print(f\"LINES={len(lines)}\") EOF python3 generate_complex_data.py ); __code=$?; pgrep -g 0 >/tmp/shell_pgrep_1d3fa73725e5.tmp 2>&1; exit $__code;", "metadata": {"source": "ps_aux", "is_root": false}}
