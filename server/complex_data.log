JSON_REPORT: {"user": "cyto", "pid": 9291, "cpu": 0.0, "mem": 0.0, "command": "/usr/bin/bash -c shopt -u promptvars nullglob extglob nocaseglob dotglob; ( cat << 'EOF' > generate_complex_data.py import json import subprocess import random  random.seed(42)  # Get real data from the machine ps_out = subprocess.getoutput(\"ps aux\").splitlines()[1:] if not ps_out:     ps_out = [\"root 1 0.1 0.2 /sbin/init\"]  lines = []  # Task 1 Ground Truth json_gt_sum = 0.0  for i in range(3000):     ps_line = ps_out[i % len(ps_out)]     parts = ps_line.split(maxsplit=10)     if len(parts) >= 11:         try:             cpu = float(parts[2])             mem = float(parts[3])             user = parts[0]                          if user == \"root\" and cpu > 0.0:                 json_gt_sum += mem                              obj = {                 \"user\": user,                 \"pid\": int(parts[1]),                 \"cpu\": cpu,                 \"mem\": mem,                 \"command\": parts[10],                 \"metadata\": {\"source\": \"ps_aux\", \"is_root\": user == \"root\"}             }             lines.append(f\"JSON_REPORT: {json.dumps(obj)}\\n\")         except:             pass  # Task 2 Ground Truth fail_ips = set() for i in range(4000):     is_fail = random.random() > 0.9     status = 'FAIL' if is_fail else 'OK'     tx_id = f\"TX-{random.randint(1000, 9999)}-{status}\"     ip = f\"10.0.{random.randint(0, 255)}.{random.randint(1, 254)}\"     size = random.randint(100, 5000)          if is_fail and size > 2000:         fail_ips.add(ip)              lines.append(f\"NETWORK_LOG - {tx_id} origin={ip} dest=192.168.1.1 payload_size={size} bytes\\n\")  # Task 3 Ground Truth def is_prime(n):     if n < 2: return False     for i in range(2, int(n**0.5) + 1):         if n % i == 0: return False     return True  latex_sum = 0 formulas = [     \"\\\\frac{{{a}}}{{{b}}}\",     \"\\\\sum_{{i=1}}^{{{a}}} {b} i\",     \"\\\\alpha_{{{a}}} + \\\\beta_{{{b}}}\" ] for i in range(3000):     a = random.randint(1, 100)     b = random.randint(1, 100)     choice = random.choice(formulas)     f_str = choice.format(a=a, b=b)          if choice.startswith(\"\\\\frac\"):         if is_prime(b):             latex_sum += a                  lines.append(f\"METRIC_LATEX - Performance equation: $ {f_str} $ evaluated at t={random.randint(0, 100)}\\n\")  # Pad to exactly 10000 lines while len(lines) < 10000:     lines.append(\"NOOP - System idle\\n\")  random.shuffle(lines)  with open(\"server/complex_data.log\", \"w\") as f:     f.writelines(lines)  print(f\"JSON_GT={round(json_gt_sum, 2)}\") print(f\"REGEX_GT={sorted(list(fail_ips))}\") print(f\"LATEX_GT={latex_sum}\") print(f\"LINES={len(lines)}\") EOF python3 generate_complex_data.py ); __code=$?; pgrep -g 0 >/tmp/shell_pgrep_1d3fa73725e5.tmp 2>&1; exit $__code;", "metadata": {"source": "ps_aux", "is_root": false}}
